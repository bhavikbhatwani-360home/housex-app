generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Developer {
  id           String       @id @default(cuid())
  email        String?      @unique
  passwordHash String?
  name         String?
  company      String
  phone        String?
  createdAt    DateTime     @default(now())
  members      TeamMember[]
  properties   Property[]
  leads        Lead[]
  bookings     Booking[]
}

model TeamMember {
  id           String    @id @default(cuid())
  developerId  String
  developer    Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  email        String    @unique
  passwordHash String
  name         String?
  role         String    @default("manager") // owner | manager | agent
  createdAt    DateTime  @default(now())
}

model Booking {
  id           String     @id @default(cuid())
  propertyId   String?
  property     Property?  @relation(fields: [propertyId], references: [id])
  propertyName String
  unitFloor    Int?
  leadId       String?
  lead         Lead?      @relation(fields: [leadId], references: [id])
  developerId  String?
  developer    Developer? @relation(fields: [developerId], references: [id])
  buyerName    String
  buyerPhone   String
  buyerPan     String?
  amount       Int        @default(999)
  status       String     @default("Paid") // Created | Paid | Refunded
  paymentRef   String?
  createdAt    DateTime   @default(now())
}

model Property {
  id                 String     @id @default(cuid())
  name               String
  developer          String
  developerId        String?
  developerAccount   Developer? @relation(fields: [developerId], references: [id])
  city               String
  locality           String
  bhk                String
  priceMin           Int // in ₹ lakh
  priceMax           Int // in ₹ lakh
  carpetSqft         Int
  facing             String
  distanceToStationM Int
  reraId             String
  status             String     @default("Live")
  amenities          String[]   @default([])
  brochureUrl        String?
  description        String?
  possession         String?
  videoUrl           String?
  images             String[]   @default([])
  units              Unit[]
  visits             Visit[]
  bookings           Booking[]
  createdAt          DateTime   @default(now())
}

model Unit {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  floor      Int
  priceLakh  Int
  facing     String
  carpetSqft Int
  available  Boolean  @default(true)
}

model Lead {
  id                 String        @id @default(cuid())
  name               String?
  phone              String?
  intent             String? // the buyer's opening ask / summary
  city               String?
  localities         String[]      @default([])
  bhk                String?
  budgetLakh         Int?
  timeline           String?
  interestedProperty String?
  status             String        @default("New")
  developerId        String?
  developer          Developer?    @relation(fields: [developerId], references: [id])
  conversation       Conversation?
  visits             Visit[]
  bookings           Booking[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Visit {
  id           String    @id @default(cuid())
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id])
  propertyName String
  leadId       String?
  lead         Lead?     @relation(fields: [leadId], references: [id])
  date         String // e.g. "Sat, 14 Jun"
  slot         String // e.g. "11:00 AM"
  mode         String // "In-person" | "Video"
  status       String    @default("Requested")
  createdAt    DateTime  @default(now())
}

model Conversation {
  id        String    @id
  leadId    String?   @unique
  lead      Lead?     @relation(fields: [leadId], references: [id])
  messages  Message[]
  createdAt DateTime  @default(now())
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "baba"
  content        String
  createdAt      DateTime     @default(now())
}
